{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".tsbuildinfo"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "dependsOn": []
    },
    "fitness": {
      "dependsOn": ["build", "typecheck"],
      "env": ["SELFWRIGHT_DATA_DIR", "SELFWRIGHT_CONFIDENTIAL_NAMES"]
    },
    "format": {
      "dependsOn": []
    }
  }
}
