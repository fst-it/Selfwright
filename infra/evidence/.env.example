# Evidence.dev source credentials — copy to .env (gitignored) and fill in values.
#
# These must match the POSTGRES_PASSWORD used in infra/docker-compose.yml (and .env.example
# at the repo root). The selfwright Postgres instance is exposed on localhost:5432 when
# Docker Compose is running.
#
# Evidence.dev v3 reads source credentials from EVIDENCE_SOURCE__<sourceName>__<option>
# environment variables. The source name here is "selfwright_db".
#
# NOTE: the exact env-var prefix format may vary with Evidence.dev version — verify against
# the Evidence docs or the GUI (http://localhost:3001/settings/connections) after first run.
EVIDENCE_SOURCE__selfwright_db__host=localhost
EVIDENCE_SOURCE__selfwright_db__port=5432
EVIDENCE_SOURCE__selfwright_db__database=selfwright
EVIDENCE_SOURCE__selfwright_db__user=selfwright
EVIDENCE_SOURCE__selfwright_db__password=
