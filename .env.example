POSTGRES_PASSWORD=selfwright
SELFWRIGHT_POSTGRES_URL=postgresql://selfwright:selfwright@localhost:5432/selfwright
SELFWRIGHT_MEMORY_URL=http://localhost:8050
# Optional: set to enable bearer-token auth on the mem0 service and the MCP adapter
MEM0_SERVICE_TOKEN=
SELFWRIGHT_MEMORY_TOKEN=
# Absolute path to your Selfwright-data repository.
# If unset, falls back to a sibling directory named Selfwright-data next to this repo.
# Set this explicitly — the fallback is a convenience only.
SELFWRIGHT_DATA_DIR=
# Optional: Adzuna aggregator credentials (https://developer.adzuna.com)
SELFWRIGHT_ADZUNA_APP_ID=
SELFWRIGHT_ADZUNA_APP_KEY=
