# Normalize line endings to LF in the repo (prevents CRLF/LF churn on Windows).
* text=auto eol=lf

# Shell scripts must stay LF.
*.sh text eol=lf

# Binary / generated artifacts — never normalize.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.docx binary
*.woff  binary
*.woff2 binary
