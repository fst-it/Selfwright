{
  "name": "@selfwright/tools",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --coverage",
    "data-leak-gate": "tsx src/data-leak-gate.ts",
    "check-text-for-pii": "tsx src/check-text-for-pii.ts",
    "named-entity-scan": "tsx src/hooks/named-entity-scan.ts",
    "commit-msg-lint": "tsx src/hooks/commit-msg-lint.ts",
    "publish-check-advisory": "tsx src/hooks/publish-check-advisory.ts",
    "prepare": "tsx src/hooks/setup-hooks.ts"
  },
  "dependencies": {
    "@selfwright/core": "workspace:*",
    "@selfwright/adapter-storage-git": "workspace:*",
    "@selfwright/adapter-storage-postgres": "workspace:*",
    "@selfwright/shared-config": "workspace:*",
    "postgres": "^3.4.0",
    "yaml": "^2.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.0",
    "tsx": "^4.0.0",
    "vitest": "^3.0.0"
  }
}
