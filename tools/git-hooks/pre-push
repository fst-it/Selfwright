#!/usr/bin/env sh
# Selfwright pre-push gate — tool-agnostic coverage (ADR 0017 §2).
#
# The true last line before anything leaves the machine: scans the commits about to
# be pushed for confidential names, reading git's standard pre-push stdin protocol
# ("<local ref> <local sha1> <remote ref> <remote sha1>", one line per ref).
#
# If lefthook is available, defer to it; it runs pre-push as defined in lefthook.yml.
# Otherwise run the named-entity scan directly — stdin is passed through unmodified.
#
# Installed automatically by `pnpm prepare` via tools/src/hooks/setup-hooks.ts.
# Lefthook will overwrite this file when `lefthook install` runs; that is
# intentional — lefthook's shim is what runs our lefthook.yml commands.

set -e

if command -v lefthook >/dev/null 2>&1; then
  exec lefthook run pre-push "$@"
fi

if command -v pnpm >/dev/null 2>&1; then
  pnpm --filter @selfwright/tools run named-entity-scan pre-push
  exit $?
fi

if command -v tsx >/dev/null 2>&1; then
  tsx tools/src/hooks/named-entity-scan.ts pre-push
  exit $?
fi

echo "[pre-push] WARNING: neither lefthook, pnpm, nor tsx found." >&2
echo "[pre-push] Named-entity scan was NOT run — install pnpm or lefthook." >&2
exit 0
